# Ports Configuration
HTTP_PORT=80
HTTPS_PORT=443
PHP_PORT=9000

# SSL Configuration
SSL_CERT_FILE=
SSL_KEY_FILE=
DH_PARAMS_FILE=./ssl/dhparam.pem

# Virtual Hosts (comma-separated)
VIRTUAL_HOSTS=localhost,example.com

# Container names
APACHE_CONTAINER_NAME=apache-prod
PHP_FPM_CONTAINER_NAME=php-fpm-prod

# Logging
LOG_LEVEL=info

# SQLCipher passphrase. Generate with:  openssl rand -hex 32
# Leave empty to keep the DB unencrypted (SQLCipher behaves as stock SQLite
# until the app issues PRAGMA key).
SQLCIPHER_KEY="00e4b2c72ccb3a8ad11c10324fb84d9eb596b5ded9212ac448f01877e685049b"
